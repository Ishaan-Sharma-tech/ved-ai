  "tech_news": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "tech_news",
    "description": "Fetch top 5 trending stories from HackerNews API and return title and URL as a clean, readable list",
    "type": "object",
    "properties": {
      "top_stories_count": {
        "type": "integer",
        "description": "Number of top stories to fetch (default: 5)"
      }
    },
    "required": [
      "top_stories_count"
    ]
  },
